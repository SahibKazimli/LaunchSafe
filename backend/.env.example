# LaunchSafe / AuditShield — environment variables

# ===============
# Put your API key in this file, but dont push it back to the repo.
# Put it in your gitignore
# ===============

# Required for the LangGraph agent. Get one from
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Optional: override the Claude model
# LAUNCHSAFE_LLM_MODEL=claude-sonnet-4-5
